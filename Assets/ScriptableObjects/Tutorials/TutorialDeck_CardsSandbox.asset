%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 11111111111111111111111111111111, type: 3}
  m_Name: TutorialDeck_CardsSandbox
  m_EditorClassIdentifier: 
  cards:
  - title: Objetivo
    body: Lleva el pato a la meta. Primero preparas la solucion; despues ejecutas
      y ves si funciona.
    icon: {fileID: 0}
  - title: "Fase de <b>Planificaci\xF3n</b>"
    body: "En <b>Planificaci\xF3n</b> el pato espera. Usa el inventario y los objetos
      indicados para preparar herramientas antes de ejecutar.\nOjo, debes usarlos
      <b>TODOS</b> antes de poder habilitarte el modo de ejecuci\xF3n."
    icon: {fileID: 0}
  - title: "Fase de <b>Ejecuci\xF3n</b>"
    body: "En <b>Ejecuci\xF3n</b>, se pone en marcha todo, pero ya no puedes controlar
      (casi) todo. \xA1Planea con intenci\xF3n para que el camino del pato sea exitoso!"
    icon: {fileID: 0}
  - title: "Objetos exclusivos a la <b>Ejecuci\xF3n</b>"
    body: '<b>Picos</b>: puedes hacer clic en ciertos bloques rompibles. Cada clic
      consume un uso.'
    icon: {fileID: 0}
  - title: "Objetos exclusivos a la <b>Planificaci\xF3n</b>"
    body: "Los siguientes objetos pueden usarse <i>solamente</i> durante la <b>Planificaci\xF3n</b>.\r\n\r\nArrastra
      el objeto que quieras usar a una zona libre del mapa. Cada objeto colocado
      consume un uso. Puedes moverlo o devolverlo al inventario antes de ejecutar.\r\n\r\n-
      <b>Bombas</b>: explotan despu\xE9s de unos segundos en un \xE1rea 3x3. \xA1Cuidado
      d\xF3nde las pones! Destruyen <b>todo</b> lo que est\xE9 dentro del \xE1rea.\r\n\r\n-
      <b>Ratas</b>: se mueven igual que Ducky. \xA1No dejes que terminen en el mismo
      lugar!"
    icon: {fileID: 0}
  - title: "\xA1Atenci\xF3n al <b>mapa</b>!"
    body: "- \xA1Cuidado con algunos bloques! No se quedan quietos...\r\n\r\n- Si
      ves <b>sensores y puertas</b>, \xFAsalos con ingenio.\n\r\n- Si el nivel es
      MUY grande, puedes mover la c\xE1mara <i>llevando el mouse a los bordes de
      tu pantalla</i> o con <i>las teclas WASD</i>, siendo\nW = Arriba\nS = Abajo\nA
      = Izquierda\nD = Derecha"
    icon: {fileID: 0}
