  m_Script: {fileID: 11500000, guid: c2afa1b37ae543b4b9818bf95f37884e, type: 3}
  m_Name: TutorialTooltipSequence_Sandbox
  m_EditorClassIdentifier: Assembly-CSharp::TutorialTooltipSequence
  persistenceId: contextual_tooltips
  steps:
  - id: planning
    message: "Arrastr\xE1 una bomba y/o una rata del <b>inventario</b> a un espacio
      libre para empezar a planificar."
    objective: 0
    placeable: {fileID: 0}
    environmentTarget: 0
  - id: bomb
    message: "Desp\xFA\xE9s de 2 segundos de ejecutar el nivel, explota y destruye
      TODO lo que entre en su \xE1rea de 3x3"
    objective: 1
    placeable: {fileID: 11400000, guid: d0728b15cdbd4b20996301c375bcd5fb, type: 2}
    environmentTarget: 0
  - id: rat
    message: "Se comporta igual que Ducky, \xA1pero no dejes que se encuentren! La
      rata MATA a Ducky en contacto"
    objective: 1
    placeable: {fileID: 11400000, guid: 9940634d1fb015e4b8d62542628ce243, type: 2}
    environmentTarget: 0
  - id: execute
    message: "Presion\xE1 <b>PROBAR NIVEL</b> para iniciar la ejecuci\xF3n.\nEsto
      s\xF3lo se habilita cuando hayas usado TODOS los objetos de planeaci\xF3n"
    objective: 2
    placeable: {fileID: 0}
    environmentTarget: 0
  - id: pickaxe
    message: "Exclusivo a la fase de ejecuci\xF3n, usalo para destruir ciertos bloques."
    objective: 3
    placeable: {fileID: 11400000, guid: 7ba5900b014d4aa2ba7df5936ff908b9, type: 2}
    environmentTarget: 0
  - id: falling_blocks
    message: <b>Cuidado!</b> Algunos bloques pueden caer cuando cambia su soporte.
    objective: 4
    placeable: {fileID: 0}
    environmentTarget: 1
  - id: sensors
    message: "F\xEDjate c\xF3mo est\xE1n dispuestos los <b>sensores</b> para abrir
      o controlar puertas."
    objective: 4
    placeable: {fileID: 0}
    environmentTarget: 2
